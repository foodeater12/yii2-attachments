{
  "name": "foodeater12/yii2-attachments",
  "description": "Fork of nemmo/yii2-attachments to upgrade to boostrap5",
  "type": "yii2-extension",
  "keywords": [
    "yii2",
    "extension",
    "attachment",
    "file",
    "upload"
  ],
  "license": "BSD-4-Clause",
  "homepage": "https://github.com/foodeater12/yii2-attachments",
  "authors": [
    {
      "name": "Austin Palanca",
      "email": "austinp18@hotmail.com"
    }
  ],
  "require": {
    "php": ">=5.4.0",
    "yiisoft/yii2": "~2.0.0",
    "kartik-v/yii2-widget-fileinput": "~1.1.1",
    "himiklab/yii2-colorbox-widget": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "~4.0",
    "phpunit/dbunit": "~1.0"
  },
  "autoload": {
    "psr-4": {
      "foodeater12\\attachments\\": "src"
    }
  },
  "extra": {
    "asset-installer-paths": {
      "npm-asset-library": "vendor/npm",
      "bower-asset-library": "vendor/bower"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "config": {
    "process-timeout": 1800,
    "fxp-asset": {
      "enabled": false
    }
  }
}
